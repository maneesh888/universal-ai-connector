{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:output",
  "title": "Universal AI Connector V1 Output",
  "description": "One indexed provider-neutral output. The relationship between kind, text, and json is a semantic constraint so future kinds can be retained.",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "urn:universal-ai-connector:contract:v1:operation-id"
    },
    "index": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9._-]{0,63}$"
    },
    "text": {
      "type": "string",
      "maxLength": 1048576
    },
    "json": {},
    "extensions": {
      "$ref": "urn:universal-ai-connector:contract:v1:extensions"
    }
  },
  "required": [
    "id",
    "index",
    "kind"
  ],
  "additionalProperties": true
}
