{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:provider-capability-profile",
  "title": "Universal AI Connector V1 Provider Capability Profile",
  "description": "Versioned provider-level capability defaults. Model-specific overrides are resolved in common Kotlin and are not a second wire DTO.",
  "type": "object",
  "properties": {
    "contractVersion": {
      "const": "1"
    },
    "providerId": {
      "$ref": "urn:universal-ai-connector:contract:v1:provider-id"
    },
    "capabilities": {
      "$ref": "urn:universal-ai-connector:contract:v1:capability-set"
    },
    "extensions": {
      "$ref": "urn:universal-ai-connector:contract:v1:extensions"
    }
  },
  "required": [
    "contractVersion",
    "providerId",
    "capabilities"
  ],
  "additionalProperties": true
}
