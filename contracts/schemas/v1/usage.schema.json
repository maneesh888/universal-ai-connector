{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:usage",
  "title": "Universal AI Connector V1 Usage",
  "description": "Canonical token accounting. Total consistency and breakdown sums are semantic constraints.",
  "type": "object",
  "properties": {
    "inputTokens": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "outputTokens": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "totalTokens": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "inputDetails": {
      "$ref": "#/$defs/tokenBreakdown"
    },
    "outputDetails": {
      "$ref": "#/$defs/tokenBreakdown"
    },
    "extensions": {
      "$ref": "urn:universal-ai-connector:contract:v1:extensions"
    }
  },
  "required": [
    "inputTokens",
    "outputTokens",
    "totalTokens"
  ],
  "additionalProperties": true,
  "$defs": {
    "tokenBreakdown": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z][a-z0-9._-]{0,63}$"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      }
    }
  }
}
