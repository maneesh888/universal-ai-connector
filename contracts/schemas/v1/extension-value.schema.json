{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:extension-value",
  "title": "Universal AI Connector V1 Extension Value",
  "description": "A recursive JSON-compatible value used by governed provider extensions. Semantic limits, including numeric token size and nesting depth, are enforced outside JSON Schema.",
  "$ref": "#/$defs/value",
  "$defs": {
    "value": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string",
          "maxLength": 16384
        },
        {
          "type": "number"
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/value"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/value"
          }
        }
      ]
    }
  }
}
