{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:extensions",
  "title": "Universal AI Connector V1 Extensions",
  "description": "A governed extension bag. Each reverse-DNS namespace owns one object payload. Byte, depth, node, member-name, string, and raw-number limits are semantic constraints.",
  "type": "object",
  "maxProperties": 16,
  "propertyNames": {
    "maxLength": 253,
    "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$"
  },
  "additionalProperties": {
    "type": "object",
    "maxProperties": 256,
    "propertyNames": {
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
    },
    "additionalProperties": {
      "$ref": "urn:universal-ai-connector:contract:v1:extension-value"
    }
  }
}
