{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:text-input",
  "title": "Universal AI Connector V1 Text Input",
  "description": "One ordered text item. Blank content and UTF-8 aggregate limits are semantic constraints.",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9._-]{0,63}$"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 262144
    }
  },
  "required": [
    "role",
    "content"
  ],
  "additionalProperties": true
}
