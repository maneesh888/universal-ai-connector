{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:stream-event",
  "title": "Universal AI Connector V1 Stream Event",
  "description": "A versioned correlated stream event. Type-specific field rules and ordering are semantic constraints.",
  "allOf": [
    {
      "$ref": "urn:universal-ai-connector:contract:v1:envelope"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9._-]{0,63}$"
        },
        "terminal": {
          "type": "boolean"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "requestId": {
          "$ref": "urn:universal-ai-connector:contract:v1:operation-id"
        },
        "responseId": {
          "$ref": "urn:universal-ai-connector:contract:v1:operation-id"
        },
        "outputId": {
          "$ref": "urn:universal-ai-connector:contract:v1:operation-id"
        },
        "outputIndex": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "delta": {
          "type": "string",
          "maxLength": 1048576
        },
        "output": {
          "$ref": "urn:universal-ai-connector:contract:v1:output"
        },
        "usage": {
          "$ref": "urn:universal-ai-connector:contract:v1:usage"
        },
        "response": {
          "$ref": "urn:universal-ai-connector:contract:v1:response"
        },
        "extensions": {
          "$ref": "urn:universal-ai-connector:contract:v1:extensions"
        }
      },
      "required": [
        "type",
        "terminal",
        "sequence",
        "responseId"
      ],
      "additionalProperties": true
    }
  ]
}
