{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:universal-ai-connector:contract:v1:capability-set",
  "title": "Universal AI Connector V1 Capability Set",
  "description": "A raw-keyed set of provider or effective-model capability declarations. Known max_schema_bytes and max_schema_depth limits apply only to structured_output. Unknown valid names, support values, and limit names remain contract data.",
  "type": "object",
  "maxProperties": 64,
  "propertyNames": {
    "minLength": 1,
    "maxLength": 64,
    "pattern": "^[a-z][a-z0-9._-]{0,63}$"
  },
  "additionalProperties": {
    "type": "object",
    "properties": {
      "support": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z][a-z0-9._-]{0,63}$"
      },
      "limits": {
        "type": "object",
        "maxProperties": 64,
        "propertyNames": {
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9._-]{0,63}$"
        },
        "additionalProperties": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "extensions": {
        "$ref": "urn:universal-ai-connector:contract:v1:extensions"
      }
    },
    "required": [
      "support"
    ],
    "additionalProperties": true
  }
}
